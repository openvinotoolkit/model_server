+		         GIT_STATUS_WT_RENAMED | GIT_STATUS_WT_TYPECHANGE))
+			++unstaged;
+
+		// Untracked
+		if (s & GIT_STATUS_WT_NEW)
+			++untracked;
+
+		// Conflicted
+		if (s & GIT_STATUS_CONFLICTED)
+			++conflicted;
+	}
+
